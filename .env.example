# ARICO Environment Variables
# Copy this file to .env and fill in your values

# --- LLM Provider ---
# Set ONE of these API keys. ARICO auto-detects which provider to use.
# If both are set, Anthropic/Claude is preferred.
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Override auto-detection
# ARICO_LLM_PROVIDER=anthropic  # or "openai"
# ARICO_LLM_MODEL=claude-sonnet-4-20250514  # or "gpt-4o-mini"

# --- LangSmith Observability ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=arico

# --- SQLite DB path (optional — defaults to arico.db in working directory) ---
# ARICO_DB_PATH=arico.db

# --- ARICO Configuration ---
# Maximum iterations for HITL modification loop
ARICO_MAX_HITL_ITERATIONS=3
# Auto-deploy threshold: campaigns costing less than this % of revenue_at_risk auto-deploy
ARICO_AUTO_DEPLOY_COST_RATIO=0.3
# Minimum ROI for auto-deployment
ARICO_AUTO_DEPLOY_MIN_ROI=1.5
